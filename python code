
import requests
from bs4 import BeautifulSoup
from reportlab.lib.pagesizes import A4
from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
from reportlab.lib.units import mm
from reportlab.lib import colors
from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, HRFlowable, PageBreak, KeepTogether
from reportlab.lib.enums import TA_CENTER
from datetime import datetime
from urllib.parse import urljoin, urlparse, urlunparse, parse_qs, urlencode
import re, os, time, hashlib


# ── URL normaliser ────────────────────────────────────────────────────────────
def normalise_url(url):
    """
    Strip fragments, query strings, and trailing slashes so that
    /ceos/, /ceos/?Sort=Newest, and /ceos/#top all become the same key.
    """
    p = urlparse(url)
    # Drop query string and fragment entirely
    clean = urlunparse((p.scheme, p.netloc, p.path.rstrip("/"), "", "", ""))
    return clean.lower()


# ── Step 1: Discover all unique pages ────────────────────────────────────────
def get_all_pages(start_url, max_pages=50):
    domain      = urlparse(start_url).netloc
    seen_norm   = set()          # normalised URL keys  (dedup check)
    seen_fetch  = set()          # exact URLs already fetched
    to_visit    = [start_url]
    ordered     = []             # URLs to actually scrape (unique only)

    headers = {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"}

    print(f"\n Discovering pages on: {domain}")

    while to_visit and len(ordered) < max_pages:
        url      = to_visit.pop(0)
        url      = url.split("#")[0].rstrip("/")   # strip fragment
        norm_url = normalise_url(url)

        if not url:
            continue
        if norm_url in seen_norm:      # already have this page (different URL, same content)
            continue
        if url in seen_fetch:
            continue

        # Skip static assets
        if re.search(r"\.(jpg|jpeg|png|gif|svg|pdf|zip|css|js|ico|xml|json|woff|ttf)$", url, re.I):
            continue

        try:
            resp = requests.get(url, headers=headers, timeout=10)
            if "text/html" not in resp.headers.get("Content-Type", ""):
                continue
            resp.raise_for_status()
        except Exception as e:
            print(f"   Skipping {url} — {e}")
            seen_norm.add(norm_url)
            seen_fetch.add(url)
            continue

        # ── Content-hash dedup ────────────────────────────────────────────────
        # Even if the URL looks different, if the HTML body is identical
        # we skip it (catches JS-rendered pages that return same content)
        content_hash = hashlib.md5(resp.text.encode()).hexdigest()
        if content_hash in seen_fetch:
            seen_norm.add(norm_url)
            continue
        seen_fetch.add(content_hash)
        seen_norm.add(norm_url)
        seen_fetch.add(url)

        ordered.append(url)
        print(f"   [{len(ordered)}] {url}")

        # Discover child links
        soup = BeautifulSoup(resp.text, "html.parser")
        for a in soup.find_all("a", href=True):
            href = a["href"].strip()
            full = urljoin(url, href).split("#")[0].rstrip("/")
            parsed = urlparse(full)

            if (parsed.scheme in ("http", "https")
                    and parsed.netloc == domain
                    and full not in seen_fetch
                    and full not in to_visit
                    and normalise_url(full) not in seen_norm):
                to_visit.append(full)

        time.sleep(0.5)

    print(f" Total unique pages found: {len(ordered)}")
    return ordered


# ── Step 2: Extract content cleanly ──────────────────────────────────────────
def extract_page_content(url):
    headers = {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"}
    try:
        resp = requests.get(url, headers=headers, timeout=15)
        resp.raise_for_status()
    except Exception:
        return f"Error loading: {url}", []

    soup = BeautifulSoup(resp.text, "html.parser")

    for tag in soup(["script", "style", "noscript", "iframe",
                     "nav", "footer", "aside", "form", "button", "meta", "link"]):
        tag.decompose()

    title_tag  = soup.find("title")
    page_title = title_tag.get_text(" ", strip=True) if title_tag else url

    content    = []
    seen_texts = set()
    all_tags   = ["h1", "h2", "h3", "h4", "h5", "h6", "p", "li"]

    for element in soup.find_all(all_tags):
        # Skip nested elements (avoid duplicating text from parent+child)
        parent, skip = element.parent, False
        while parent and parent.name:
            if parent.name in all_tags:
                skip = True
                break
            parent = parent.parent
        if skip:
            continue

        text = re.sub(r"\s+", " ", element.get_text(separator=" ", strip=True)).strip()
        if not text or len(text) < 4:
            continue

        # Filter boilerplate
        boilerplate = ["cookie", "google analytics", "privacy policy",
                       "enable javascript", "enable cookies"]
        if any(b in text.lower() for b in boilerplate):
            continue

        if text in seen_texts:
            continue
        seen_texts.add(text)
        content.append({"tag": element.name, "text": text})

    return page_title, content


# ── Step 3: Build the PDF ─────────────────────────────────────────────────────
def build_pdf(all_pages_data, start_url, output_file):
    doc = SimpleDocTemplate(
        output_file, pagesize=A4,
        leftMargin=22*mm, rightMargin=22*mm,
        topMargin=22*mm, bottomMargin=22*mm,
    )

    DARK  = colors.HexColor("#1a1a2e")
    BLUE  = colors.HexColor("#2c3e7a")
    LBLUE = colors.HexColor("#4a90d9")
    GRAY  = colors.HexColor("#555555")
    LGRAY = colors.HexColor("#888888")
    BODY  = colors.HexColor("#2d2d2d")
    WHITE = colors.white

    s_cover_title  = ParagraphStyle("CT",  fontSize=24, textColor=DARK,
        alignment=TA_CENTER, fontName="Helvetica-Bold", spaceAfter=8, leading=30)
    s_cover_meta   = ParagraphStyle("CM",  fontSize=10, textColor=LGRAY,
        alignment=TA_CENTER, spaceAfter=20, leading=16)
    s_toc_heading  = ParagraphStyle("TH",  fontSize=12, textColor=DARK,
        fontName="Helvetica-Bold", spaceAfter=8, spaceBefore=4)
    s_toc_item     = ParagraphStyle("TI",  fontSize=9,  textColor=BODY,
        leading=14, spaceAfter=1)
    s_toc_url      = ParagraphStyle("TU",  fontSize=7,  textColor=LBLUE,
        leading=10, leftIndent=12, spaceAfter=7, fontName="Helvetica-Oblique")
    s_banner       = ParagraphStyle("SB",  fontSize=13, textColor=WHITE,
        backColor=DARK, fontName="Helvetica-Bold",
        spaceBefore=0, spaceAfter=0, borderPad=(5,5,5,5), leading=18)
    s_banner_url   = ParagraphStyle("SU",  fontSize=8,  textColor=LBLUE,
        fontName="Helvetica-Oblique", spaceAfter=10, spaceBefore=4, leading=11)
    s_h1 = ParagraphStyle("H1", fontSize=15, textColor=DARK,
        fontName="Helvetica-Bold", spaceBefore=14, spaceAfter=6,  leading=20, keepWithNext=True)
    s_h2 = ParagraphStyle("H2", fontSize=13, textColor=BLUE,
        fontName="Helvetica-Bold", spaceBefore=12, spaceAfter=5,  leading=18, keepWithNext=True)
    s_h3 = ParagraphStyle("H3", fontSize=11, textColor=GRAY,
        fontName="Helvetica-Bold", spaceBefore=10, spaceAfter=4,  leading=16, keepWithNext=True)
    s_h4 = ParagraphStyle("H4", fontSize=10, textColor=GRAY,
        fontName="Helvetica-Bold", spaceBefore=8,  spaceAfter=3,  leading=14, keepWithNext=True)
    s_body = ParagraphStyle("Bo", fontSize=9, textColor=BODY,
        leading=15, spaceAfter=7, spaceBefore=2)
    s_li   = ParagraphStyle("Li", fontSize=9, textColor=BODY,
        leading=14, leftIndent=14, spaceAfter=4, bulletIndent=5)
    s_footer = ParagraphStyle("Ft", fontSize=7, textColor=colors.HexColor("#bbbbbb"),
        alignment=TA_CENTER)

    tag_map = {
        "h1": s_h1, "h2": s_h2, "h3": s_h3,
        "h4": s_h4, "h5": s_h4, "h6": s_h4,
        "p": s_body, "li": s_li,
    }

    def safe(t):
        return t.replace("&","&amp;").replace("<","&lt;").replace(">","&gt;")

    story = []

    # Cover
    story.append(Spacer(1, 25*mm))
    domain = urlparse(start_url).netloc
    story.append(Paragraph(safe(domain), s_cover_title))
    story.append(Paragraph(
        f"Full Website Scrape &nbsp;|&nbsp; {len(all_pages_data)} unique pages "
        f"&nbsp;|&nbsp; {datetime.now().strftime('%d %B %Y, %H:%M')}",
        s_cover_meta))
    story.append(HRFlowable(width="100%", thickness=2, color=DARK, spaceAfter=14))

    # TOC
    story.append(Paragraph("Pages Scraped", s_toc_heading))
    for i, (url, title, _) in enumerate(all_pages_data, 1):
        story.append(Paragraph(f"<b>{i}.</b>  {safe(title)}", s_toc_item))
        story.append(Paragraph(safe(url), s_toc_url))
    story.append(PageBreak())

    # Content pages
    for page_num, (url, page_title, content) in enumerate(all_pages_data, 1):
        header = [
            Spacer(1, 2*mm),
            Paragraph(safe(page_title), s_banner),
            Paragraph(safe(url), s_banner_url),
        ]
        if not content:
            header.append(Paragraph("No content extracted from this page.", s_body))
            story.append(KeepTogether(header))
        else:
            first = content[0]
            prefix = "• " if first["tag"] == "li" else ""
            try:
                header.append(Paragraph(prefix + safe(first["text"]), tag_map.get(first["tag"], s_body)))
            except Exception:
                pass
            story.append(KeepTogether(header))
            for item in content[1:]:
                prefix = "• " if item["tag"] == "li" else ""
                try:
                    story.append(Paragraph(prefix + safe(item["text"]), tag_map.get(item["tag"], s_body)))
                except Exception:
                    pass

        if page_num < len(all_pages_data):
            story.append(Spacer(1, 8*mm))
            story.append(HRFlowable(width="100%", thickness=0.5,
                                     color=colors.HexColor("#cccccc"), spaceAfter=0))
            story.append(PageBreak())

    story.append(Spacer(1, 12*mm))
    story.append(HRFlowable(width="100%", thickness=0.5,
                             color=colors.HexColor("#dddddd"), spaceAfter=5))
    story.append(Paragraph(
        f"Generated by Simple Web Scraper &nbsp;|&nbsp; {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}",
        s_footer))
    doc.build(story)


# ── Helpers ───────────────────────────────────────────────────────────────────
def make_filename(url):
    name = re.sub(r"https?://", "", url)
    name = re.sub(r"[^\w]", "_", name).strip("_")
    return re.sub(r"_+", "_", name)[:50] + "_full.pdf"


# ── Main ──────────────────────────────────────────────────────────────────────
if __name__ == "__main__":
    print("=" * 55)
    print("   Full Website Scraper -> PDF")
    print("=" * 55)

    url = input("\nEnter website URL: ").strip()
    if not url.startswith("http"):
        url = "https://" + url

    max_pages_input = input("Max pages to scrape? (press Enter for 50): ").strip()
    max_pages = int(max_pages_input) if max_pages_input.isdigit() else 50

    output_file = make_filename(url)

    try:
        all_urls = get_all_pages(url, max_pages=max_pages)

        all_pages_data = []
        for i, page_url in enumerate(all_urls, 1):
            print(f" Scraping [{i}/{len(all_urls)}]: {page_url}")
            title, content = extract_page_content(page_url)
            all_pages_data.append((page_url, title, content))
            time.sleep(0.3)

        print(f"\n Building PDF -> {output_file}")
        build_pdf(all_pages_data, url, output_file)

        print(f"\n Done! PDF saved as : {output_file}")
        print(f" Location           : {os.path.abspath(output_file)}")
        print(f" Unique pages       : {len(all_pages_data)}")

    except requests.exceptions.ConnectionError:
        print("\n Error: Could not connect. Check your internet or the URL.")
    except requests.exceptions.HTTPError as e:
        print(f"\n HTTP Error: {e}")
    except Exception as e:
        print(f"\n Something went wrong: {e}")
